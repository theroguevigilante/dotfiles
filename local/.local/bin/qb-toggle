#!/bin/sh

# If qbittorrent-nox is running, will ask to kill, else will ask to start.

if pidof qbittorrent-nox >/dev/null ;
then
	[ "$(printf "No\\nYes" | dmenu -i -p "Turn off qbittorrent-daemon?")" = "Yes" ] && killall qbittorrent-nox && notify-send "qbittorrent-daemon disabled."
else
	ifinstalled qbittorrent-nox || exit
	[ "$(printf "No\\nYes" | dmenu -i -p "Turn on qbittorrent-daemon?")" = "Yes" ] && qbittorrent-nox --daemon && notify-send "qbittorrent-daemon enabled."
fi
sleep 3 && pkill -RTMIN+7 "${STATUSBAR:-dwmblocks}"
